{
  "manifest_version": 3,
  "name": "Redline",
  "version": "0.1.0",
  "description": "Personal YouTube productivity tweaks. First feature: a Watch Later toggle anchored next to the native Save button.",
  "action": {
    "default_title": "Redline",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/toolbar-16.png",
      "24": "icons/toolbar-24.png",
      "32": "icons/toolbar-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "*://www.youtube.com/*"
  ],
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-DlXsYhbl.js"
      ],
      "matches": [
        "*://www.youtube.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "resources": [
        "assets/storage-B_H4Ekmf.js",
        "assets/storage-B_H4Ekmf.js.map",
        "assets/content.ts-D262PRlh.js",
        "assets/content.ts-D262PRlh.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
