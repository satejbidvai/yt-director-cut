{
  "manifest_version": 3,
  "name": "Productive YT",
  "version": "0.1.0",
  "description": "Personal YouTube productivity tweaks. First feature: a Watch Later toggle anchored next to the native Save button.",
  "action": {
    "default_title": "Productive YT",
    "default_popup": "src/popup/index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": ["*://www.youtube.com/*"],
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
